<!DOCTYPE html>
<html lang="en">
<head>
  <title>RingZone</title>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="description" content="RingZone">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <link rel="stylesheet" href="/styles/bootstrap4/bootstrap.min.css">
  <link rel="stylesheet" href="/plugins/font-awesome-4.7.0/css/font-awesome.min.css">
  <link rel="stylesheet" href="/plugins/OwlCarousel2-2.2.1/owl.carousel.css">
  <link rel="stylesheet" href="/plugins/OwlCarousel2-2.2.1/owl.theme.default.css">
  <link rel="stylesheet" href="/plugins/OwlCarousel2-2.2.1/animate.css">
  <link rel="stylesheet" href="/styles/main_styles.css">
  <link rel="stylesheet" href="/styles/responsive.css">
  <link rel="stylesheet" href="/styles/responsive.css">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    
.card.product-card {
  display: flex;
  flex-direction: column;
  height: 100%;
  z-index: 5;
}

/* Modern Loading Spinner */
.page-loader {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.95);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 99999;
  backdrop-filter: blur(5px);
}

.page-loader.active {
  display: flex;
}

.spinner-container {
  text-align: center;
}

.modern-spinner {
  width: 60px;
  height: 60px;
  border: 4px solid #f3f3f3;
  border-top: 4px solid #ff7f50;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto 20px;
}

.spinner-dots {
  display: flex;
  gap: 8px;
  justify-content: center;
  margin-top: 15px;
}

.spinner-dot {
  width: 10px;
  height: 10px;
  background: #ff7f50;
  border-radius: 50%;
  animation: bounce 1.4s infinite ease-in-out both;
}

.spinner-dot:nth-child(1) {
  animation-delay: -0.32s;
}

.spinner-dot:nth-child(2) {
  animation-delay: -0.16s;
}

.loading-text {
  color: #333;
  font-size: 16px;
  font-weight: 600;
  margin-top: 10px;
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

@keyframes bounce {
  0%, 80%, 100% { 
    transform: scale(0);
    opacity: 0.5;
  } 
  40% { 
    transform: scale(1);
    opacity: 1;
  }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.card.product-card .card-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.card.product-card .btn {
  display: inline-block;
  width: auto;
}

.logout-text {
    background-color: #ff7f50 !important; 
    color: white !important;            
    font-size: 1.1rem;                  
    font-weight: bold;
    border: none;                         
    padding: 5px 15px;                    
    transition: 0.3s;                     
}


.logout-text:hover {
    background-color: #e66e45 !important; 
    color: white !important;
}


.product-img {
  height: 220px;
  object-fit: contain;
  width: 100%;
  padding: 10px;
  background-color: #f9f9f9;
  border-bottom: 1px solid #eee;
  border-top-left-radius: 0.375rem;
  border-top-right-radius: 0.375rem;
}


.product-card {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 100%;
  border-radius: 10px;
  overflow: hidden;
  background-color: #fff;
  border: 1px solid #ddd;
  transition: 0.3s ease;
}

.cart-count {
  font-size: 0.7rem;
  padding: 0.15em 0.4em;
}
.product-card:hover {
  box-shadow: 0 6px 18px rgba(0, 0, 0, 0.1);
  transform: translateY(-3px);
}


.product-card .card-body {
  padding: 1rem;
  display: flex;
  flex-direction: column;
  flex-grow: 1;
}


.product-card .card-title {
  font-size: 1rem;
  font-weight: 600;
  color: #333;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 0.5rem;
}


.product-card .text-primary {
  font-size: 1rem;
  font-weight: bold;
  margin-bottom: 0.5rem;
  color: #007bff !important;
}


.product-card .btn-outline-primary {
  font-size: 0.875rem;
  padding: 6px 12px;
  border-radius: 4px;
}


.product-card .fa-heart {
  font-size: 1.25rem;
  transition: color 0.2s;
}

.product-card .fa-heart:hover {
  color: #dc3545;
}


.text-truncate {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}


.banner_item {
  height: 250px;
  border-radius: 12px;
  background-size: cover;
  background-position: center;
  position: relative;
  overflow: hidden;
  transition: transform 0.4s ease;
  margin-bottom: 20px;
  display: flex;
  align-items: flex-end;
  padding: 20px;
}

.banner_item:hover {
  transform: scale(1.03);
}

.banner_overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.3), rgba(0,0,0,0.6));
  z-index: 1;
}

.banner_category {
  position: absolute;
  bottom: 20px;
  left: 20px;
  z-index: 2;
}

.banner_category a {
  background-color: rgba(255, 255, 255, 0.9);
  padding: 10px 20px;
  border-radius: 6px;
  color: #000;
  font-weight: bold;
  font-size: 1rem;
  text-transform: uppercase;
  text-decoration: none;
  transition: all 0.3s ease;
}

.banner_category a:hover {
  background-color: #ff7f50;
  color: #fff;
}


@media (max-width: 768px) {
  .banner_item {
    height: 180px;
  }

  .banner_category a {
    font-size: 0.9rem;
    padding: 8px 16px;
  }
}

@media (max-width: 480px) {
  .banner_item {
    height: 150px;
  }
}
/* ── Professional Navbar ── */
:root {
  --brand-teal: #1e918b;
  --brand-teal-light: #16c79a;
  --nav-text: #1a1a1a;
}

.main_nav_container {
  height: 68px;
  display: flex;
  align-items: center;
  transition: box-shadow 0.3s ease;
}

.header.scrolled .main_nav_container {
  box-shadow: 0 4px 20px rgba(0,0,0,0.08);
}

/* Nav links */
.navbar_menu {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.25rem;
  list-style: none;
  margin: 0;
  padding: 0;
  width: 100%;
}

.navbar_menu li a {
  position: relative;
  display: inline-block;
  padding: 8px 18px;
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--nav-text);
  text-decoration: none;
  letter-spacing: 0.3px;
  border-radius: 8px;
  transition: color 0.25s ease, background 0.25s ease;
}

.navbar_menu li a::after {
  content: '';
  position: absolute;
  bottom: 3px;
  left: 18px;
  right: 18px;
  height: 2px;
  background: linear-gradient(90deg, var(--brand-teal), var(--brand-teal-light));
  border-radius: 2px;
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.3s ease;
}

.navbar_menu li a:hover,
.navbar_menu li a.nav-active {
  color: var(--brand-teal);
  background: rgba(30, 145, 139, 0.07);
  text-decoration: none;
}

.navbar_menu li a:hover::after,
.navbar_menu li a.nav-active::after {
  transform: scaleX(1);
}

/* Icon buttons */
.navbar_user {
  list-style: none;
  margin: 0;
  padding: 0;
  gap: 4px;
}

.navbar_user li a:not(.user-avatar-link):not(.wishlist-navbar-icon) {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38px;
  height: 38px;
  border-radius: 10px;
  color: var(--nav-text);
  font-size: 1rem;
  text-decoration: none;
  transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
}

.navbar_user li a:not(.user-avatar-link):not(.wishlist-navbar-icon):hover {
  background: rgba(30, 145, 139, 0.1);
  color: var(--brand-teal);
  transform: translateY(-1px);
}

/* Wishlist icon */
.wishlist-navbar-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38px;
  height: 38px;
  border-radius: 10px;
  color: var(--nav-text);
  font-size: 1rem;
  text-decoration: none;
  transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
}

.wishlist-navbar-icon:hover {
  background: rgba(30, 145, 139, 0.1);
  color: var(--brand-teal);
  transform: translateY(-1px);
}

/* User avatar */
.user-avatar {
  width: 38px;
  height: 38px;
  border-radius: 10px;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 1rem;
  text-transform: uppercase;
  cursor: pointer;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  box-shadow: 0 2px 8px rgba(0,0,0,0.15);
}

.user-avatar:hover {
  transform: translateY(-1px);
  box-shadow: 0 4px 14px rgba(0,0,0,0.2);
}

.user-avatar-link { display: inline-block; }

/* Logout button */
.logout-text {
  font-size: 0.82rem !important;
  font-weight: 600 !important;
  padding: 7px 14px !important;
  border-radius: 8px !important;
  background: linear-gradient(135deg, #ff4646, #ff6b6b) !important;
  color: white !important;
  border: none !important;
  letter-spacing: 0.3px;
  transition: transform 0.2s ease, box-shadow 0.2s ease !important;
  box-shadow: 0 2px 8px rgba(255,70,70,0.3);
}

.logout-text:hover {
  transform: translateY(-1px) !important;
  box-shadow: 0 4px 14px rgba(255,70,70,0.4) !important;
  text-decoration: none;
  color: white !important;
}

/* Sign-in icon */
.signin-btn-icon {
  display: flex !important;
  align-items: center;
  justify-content: center;
  width: 38px !important;
  height: 38px !important;
  border-radius: 10px !important;
  background: rgba(30,145,139,0.08) !important;
  border: none !important;
  color: var(--brand-teal) !important;
  font-size: 1rem;
  transition: background 0.2s ease, transform 0.2s ease;
  padding: 0 !important;
}

.signin-btn-icon:hover {
  background: rgba(30,145,139,0.18) !important;
  transform: translateY(-1px);
}

.signin-btn-icon i { color: var(--brand-teal) !important; }

/* Dropdown */
.dropdown:hover .dropdown-content { display: block; }

.dropdown-content {
  display: none;
  position: absolute;
  background: #fff;
  min-width: 160px;
  box-shadow: 0 8px 24px rgba(0,0,0,0.12);
  border-radius: 10px;
  z-index: 1000;
  right: 0;
  overflow: hidden;
  border: 1px solid #f0f0f0;
}

.dropdown-content a {
  color: #333;
  padding: 10px 16px;
  text-decoration: none;
  display: block;
  font-size: 0.9rem;
  transition: background 0.2s;
}

.dropdown-content a:hover {
  background: rgba(30,145,139,0.08);
  color: var(--brand-teal);
}

.sign-in-link {
  font-size: 0.9rem;
  color: #333;
  text-decoration: none;
  font-weight: 600;
}

.sign-in-link:hover { color: var(--brand-teal); }


.timer_num {
  width: 90px;
  height: 90px;
  font-size: 2rem;
  font-weight: bold;
}

.timer_unit {
  font-size: 1rem;
  color: #555;
}

  </style>
</head>

<body >
<div class="super_container">

<!-- Modern Page Loader -->
<div id="pageLoader" class="page-loader">
  <div class="spinner-container">
    <div class="modern-spinner"></div>
    <div class="loading-text">Loading...</div>
    <div class="spinner-dots">
      <div class="spinner-dot"></div>
      <div class="spinner-dot"></div>
      <div class="spinner-dot"></div>
    </div>
  </div>
</div>

  <header class="header trans_300" style="position: fixed; top: 0; left: 0; width: 100%; z-index: 100; background: #fff;">


    <div class="top_nav">
      <div class="container">
        <div class="row">
          <div class="col-md-6">
            <div class="top_nav_left">🚚 Free & Fast Delivery on All Mobile Orders Across India</div>
          </div>
          <div class="col-md-6 text-right">
            <div class="top_nav_right">
              <ul class="top_nav_menu">
                <li class="currency">
                  <a href="#">INR<i class="fa fa-angle-down"></i></a>
                  <ul class="currency_selection">
                    <li><a href="#">cad</a></li>
                    <li><a href="#">aud</a></li>
                    <li><a href="#">eur</a></li>
                    <li><a href="#">gbp</a></li>
                  </ul>
                </li>
                <li class="language">
                  <a href="#">English <i class="fa fa-angle-down"></i></a>
                  <ul class="language_selection">
                    <li><a href="#">French</a></li>
                    <li><a href="#">Italian</a></li>
                    <li><a href="#">German</a></li>
                    <li><a href="#">Spanish</a></li>
                  </ul>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="main_nav_container">
      <div class="container">
        <div class="row align-items-center justify-content-between" style="height: 68px; flex-wrap: nowrap;">

          <!-- Hamburger (mobile only) -->
          <div class="col-auto d-md-none">
            <button class="nav-hamburger" id="navHamburger" aria-label="Toggle menu">
              <span></span><span></span><span></span>
            </button>
          </div>

         
          <div class="col-auto d-flex align-items-center" style="height: 68px; overflow: hidden;">
            <a href="/" class="d-flex align-items-center" style="text-decoration:none; height: 100%;">
              <img src="/images/logoicon.png" alt="RingZone" style="height: 56px; width: auto; display: block; object-fit: contain;">
            </a>
          </div>

          <div class="col">
            <nav class="navbar justify-content-center w-100">
  <ul class="navbar_menu" id="navbarMenu">
    <li><a href="/">Home</a></li>
    <li><a href="/shopping-pageList">Shop</a></li>
    <li><a href="/page-about">About Us</a></li>
  </ul>
</nav>

          </div>
          <div class="col-auto">
            <ul class="navbar_user d-flex align-items-center mb-0">

              <% if (locals.user && locals.user !== null) { %>
                <%
  const colors = ['#FF5733', '#33B5E5', '#FFB400', '#4CAF50', '#9C27B0', '#3F51B5', '#E91E63', '#795548'];
  const getColorFromName = (name) => {
    const charCodeSum = name
      .toUpperCase()
      .split('')
      .reduce((sum, char) => sum + char.charCodeAt(0), 0);
    return colors[charCodeSum % colors.length];
  };
  const userColor = getColorFromName(locals.user.firstname);
%>

<li class="me-3">
  <a href="/user-profile" class="user-avatar-link">
    <div class="user-avatar" style="background-color:<%- userColor %>;">
      <%= locals.user.firstname.charAt(0).toUpperCase() %>
    </div>
  </a>
</li>
              <% } else { %>
                <li class="me-3">
                  <a href="/login" class="signin-btn-icon" title="Sign In">
                    <i class="fa fa-user-plus" aria-hidden="true"></i>
                  </a>
                </li>
              <% } %>
 
              <li class="me-3">
<a href="/wishlist" class="wishlist-navbar-icon position-relative" id="navbarWishlistIcon">
  <i class="fa fa-heart-o" aria-hidden="true"></i>
  <span id="wishlist-count" class="cart-count position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="<%= wishlistLength > 0 ? '' : 'display:none;' %>">
    <%= wishlistLength %>
  </span>
</a>

</li>
              <li class="me-3"><a href="#"><i class="fa fa-search" aria-hidden="true"></i></a></li>
             <li class="me-3 position-relative">
               <a href="/user-cart">
                 <i class="fa fa-shopping-cart" aria-hidden="true"></i>
                 <span id="cart-count" class="cart-count position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                   <%= cartCount %>
                 </span>
               </a>
             </li>
             <% if (locals.user && locals.user !== null) { %>
             <li class="me-3">
              <button onclick="confirmLogout(event)" class="btn  logout-text">
                Logout
              </button>
             </li>
             <% } %>

            </ul>
          </div>

        </div>
      </div>
    </div>

  </header>

</div>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  const _swalFire = Swal.fire.bind(Swal);
  Swal.fire = function(a, b, c) {
    let opts = (typeof a === 'object' && a !== null) ? { ...a } : { title: a, text: b, icon: c };
    const noAutoClose = ['question', 'warning'].includes(opts.icon) && (opts.input || opts.showCancelButton);
    if (!noAutoClose && opts.timer === undefined) {
      opts.timer = opts.icon === 'success' ? 2000 : 2500;
      opts.timerProgressBar = true;
      opts.showConfirmButton = opts.showConfirmButton !== undefined ? opts.showConfirmButton : false;
    }
    return _swalFire(opts);
  };

  function showLoader() {
    const loader = document.getElementById('pageLoader');
    if (loader) loader.classList.add('active');
  }

  function hideLoader() {
    const loader = document.getElementById('pageLoader');
    if (loader) loader.classList.remove('active');
  }

  
  document.addEventListener('DOMContentLoaded', function() {
    hideLoader();

    // Active nav link
    const currentPath = window.location.pathname;
    document.querySelectorAll('.navbar_menu li a').forEach(link => {
      const href = link.getAttribute('href');
      if (href && (currentPath === href || (href !== '/' && currentPath.startsWith(href)))) {
        link.classList.add('nav-active');
      }
    });

    // Scroll shadow on header
    const header = document.querySelector('.header');
    window.addEventListener('scroll', () => {
      header.classList.toggle('scrolled', window.scrollY > 10);
    });

    document.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', function(e) {
        const href = this.getAttribute('href');
        
      
        if (
          !href || 
          href === '#' || 
          href.startsWith('javascript:') ||
          href.includes('logout') ||
          this.classList.contains('wishlist-icon') ||
          this.classList.contains('wishlist-navbar-icon') ||
          this.target === '_blank' ||
          href.startsWith('http') && !href.includes(window.location.hostname)
        ) {
          return;
        }

        
        showLoader();
      });
    });

    
    document.querySelectorAll('form').forEach(form => {
      form.addEventListener('submit', function(e) {
        
        if (!this.classList.contains('no-loader')) {
          showLoader();
        }
      });
    });

    
    window.addEventListener('pageshow', function(event) {
      if (event.persisted) {
        hideLoader();
      }
    });
  });

  function confirmLogout(event) {
    event.preventDefault();
    Swal.fire({
      title: 'Are you sure you want to logout?',
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#d33',
      cancelButtonColor: '#3085d6',
      confirmButtonText: 'Yes, Logout',
      background: '#fff',
    }).then((result) => {
      if (result.isConfirmed) {
        showLoader();
        window.location.href = '/logout';
      }
    });
  }
  async function updateWishlistCount() {
    try {
      const response = await fetch('/api/wishlist-count');
      const data = await response.json();

      const count = data.count;
      const wishlistCountEl = document.getElementById('wishlist-count');

      if (count > 0) {
        wishlistCountEl.textContent = count;
        wishlistCountEl.style.display = 'inline-block';
      } else {
        wishlistCountEl.style.display = 'none';
      }
    } catch (err) {
      console.error('Error fetching wishlist count:', err);
    }
  }

  
  document.addEventListener('DOMContentLoaded', updateWishlistCount);
  

  document.body.addEventListener('click', async function (e) {
    const btn = e.target.closest('.wishlist-btn');
    if (!btn) return;
    const productId = btn.dataset.productId;
    try {
      const response = await fetch('/wishlist/toggle', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ productId })
      });
      const result = await response.json();
      if (result.success) {
        updateWishlistCount();
        btn.classList.toggle('active');
      } else {
        alert(result.message || 'Could not update wishlist');
      }
    } catch (err) {
      console.error('Error updating wishlist:', err);
    }
  });

  // Hamburger menu toggle
  document.addEventListener('DOMContentLoaded', function() {
    const hamburger = document.getElementById('navHamburger');
    const menu = document.getElementById('navbarMenu');
    if (hamburger && menu) {
      hamburger.addEventListener('click', function() {
        hamburger.classList.toggle('open');
        menu.classList.toggle('open');
      });
      // Close menu when a link is clicked
      menu.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          hamburger.classList.remove('open');
          menu.classList.remove('open');
        });
      });
    }

    // Filter toggle for shopping page
    const filterBtn = document.getElementById('filterToggleBtn');
    const sidebar = document.querySelector('.product-list-page .sidebar');
    if (filterBtn && sidebar) {
      filterBtn.addEventListener('click', function() {
        sidebar.classList.toggle('filter-open');
        filterBtn.textContent = sidebar.classList.contains('filter-open') ? '✕ Hide Filters' : '⚙ Show Filters';
      });
    }
  });
</script>
</body>
</html>
