<%-include('../../views/partials/user/header')%>
<div class="main_slider" style="background-image: url('/images/13.jpg'); background-size: cover; background-position: center; position: relative; margin-top: 118px;">
  <div class="container fill_height" style="position: relative; z-index: 2;">
    <div class="row align-items-center fill_height">
      <div class="col">
       <div class="main_slider_content text-white ms-0 me-4">
  <h6 class="text-dark me-3">Latest Smartphones. Best Prices. Guaranteed.</h6>
  <h1 class="text-dark me-3">Up to 40% Off Top Mobile Brands</h1>
  <a href="/shopping-pageList" class="shop-now-cta">
    <span class="shop-now-cta__text">Shop Now</span>
    <span class="shop-now-cta__icon"><i class="fa fa-arrow-right"></i></span>
    <span class="shop-now-cta__shimmer"></span>
  </a>
</div>

        </div>
      </div>
    </div>
  </div>
</div>

<!-- Enhanced New Arrivals Section -->
<section class="new_arrivals py-5">
  <div class="container">
    <!-- Styled Section Header -->
    <div class="row mb-5">
      <div class="col text-center position-relative">
        <div class="section-heading-wrapper">
          <h2 class="section-title">New Arrivals</h2>
          <div class="title-underline">
            <div class="title-underline-core"></div>
          </div>
          <p class="section-subtitle text-muted">Discover our latest collection of smartphones</p>
        </div>
      </div>
    </div>
    
    <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-5 g-3">
      <% for(let i = 0; i < Math.min(products.length, 10); i++) { 
        const product = products[i];
        const variant = product.variants[0];
        const hasDiscount = variant.discountPrice && variant.discountPrice < variant.regularPrice;
        const discountPercentage = hasDiscount ? Math.round(((variant.regularPrice - variant.discountPrice) / variant.regularPrice) * 100) : 0;
      %>
        <div class="col">
          <a href="/products/<%= product._id %>" class="pcard">
            <div class="pcard__img-wrap">
              <img src="/<%= product.images[0] %>" alt="<%= product.productName %>" class="pcard__img">
              <% if (hasDiscount && discountPercentage > 0) { %>
                <span class="pcard__badge pcard__badge--off"><%= discountPercentage %>% off</span>
              <% } %>
            </div>
            <div class="pcard__body">
              <p class="pcard__brand"><%= product.brand.name %></p>
              <p class="pcard__name"><%= product.productName.length > 40 ? product.productName.slice(0, 40) + '…' : product.productName %></p>
              <div class="pcard__price-row">
                <span class="pcard__price">₹<%= (hasDiscount ? variant.discountPrice : variant.regularPrice).toLocaleString('en-IN') %></span>
                <% if (hasDiscount) { %>
                  <span class="pcard__mrp">₹<%= variant.regularPrice.toLocaleString('en-IN') %></span>
                <% } %>
              </div>
            </div>
          </a>
        </div>
      <% } %>
    </div>
  </div>
</section>

<style>
/* Modern Home Page Styling */

/* Hero/Main Slider Section */
.main_slider {
  min-height: 600px;
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
}

.main_slider::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(0,0,0,0.3), rgba(0,0,0,0.1));
  z-index: 1;
}

.main_slider_content {
  animation: fadeInUp 1s ease-out;
}

.main_slider_content h6 {
  font-size: 1.2rem;
  font-weight: 600;
  margin-bottom: 15px;
  letter-spacing: 1px;
  text-transform: uppercase;
  background: rgba(255,255,255,0.9);
  padding: 8px 20px;
  border-radius: 25px;
  display: inline-block;
  box-shadow: 0 4px 15px rgba(0,0,0,0.1);
}

.main_slider_content h1 {
  font-size: 3.5rem;
  font-weight: 800;
  margin-bottom: 30px;
  line-height: 1.2;
  text-shadow: 2px 2px 8px rgba(0,0,0,0.3);
  background: rgba(255,255,255,0.95);
  padding: 15px 25px;
  border-radius: 15px;
  display: inline-block;
}

.red_button {
  display: none;
}

.shop-now-cta {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 12px;
  margin-top: 28px;
  padding: 16px 36px;
  background: linear-gradient(135deg, #1e918b 0%, #16c79a 100%);
  color: #fff;
  font-size: 1.05rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  border-radius: 50px;
  text-decoration: none;
  overflow: hidden;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  box-shadow: 0 8px 28px rgba(30, 145, 139, 0.45);
}

.shop-now-cta__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 32px;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  transition: transform 0.3s ease, background 0.3s ease;
}

.shop-now-cta__shimmer {
  position: absolute;
  top: 0;
  left: -75%;
  width: 50%;
  height: 100%;
  background: linear-gradient(120deg, transparent, rgba(255,255,255,0.3), transparent);
  transform: skewX(-20deg);
  animation: shimmer 2.8s infinite;
}

@keyframes shimmer {
  0%   { left: -75%; }
  60%  { left: 130%; }
  100% { left: 130%; }
}

.shop-now-cta:hover {
  transform: translateY(-4px);
  box-shadow: 0 16px 40px rgba(30, 145, 139, 0.55);
  color: #fff;
  text-decoration: none;
}

.shop-now-cta:hover .shop-now-cta__icon {
  transform: translateX(4px);
  background: rgba(255,255,255,0.35);
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* New Arrivals Section Styling */
.new_arrivals {
  background: #f1f3f6;
  padding: 40px 0 !important;
}

.section-heading-wrapper {
  padding-bottom: 20px;
}

.section-title {
  font-size: 1.4rem;
  font-weight: 700;
  color: #212121;
  display: inline-block;
  margin-bottom: 4px;
  background: linear-gradient(135deg, #1e918b, #16c79a);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.section-title:after {
  content: '';
  position: absolute;
  width: 40px;
  height: 3px;
  background: linear-gradient(90deg, #1e918b, #16c79a);
  bottom: -8px;
  left: 50%;
  transform: translateX(-50%);
  border-radius: 2px;
}

.title-underline { display: none; }

.section-subtitle {
  font-size: 0.9rem;
  color: #878787;
  margin: 8px auto 0;
}

/* Product Card — Flipkart/Amazon compact style */
.pcard {
  display: block;
  background: #fff;
  border: 1px solid #e8e8e8;
  border-radius: 4px;
  text-decoration: none;
  color: inherit;
  transition: box-shadow 0.2s ease;
  overflow: hidden;
}

.pcard:hover {
  box-shadow: 0 4px 16px rgba(0,0,0,0.12);
  text-decoration: none;
  color: inherit;
}

.pcard__img-wrap {
  position: relative;
  background: #f5f5f5;
  height: 160px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.pcard__img {
  max-height: 140px;
  max-width: 100%;
  object-fit: contain;
  transition: transform 0.3s ease;
  padding: 8px;
}

.pcard:hover .pcard__img {
  transform: scale(1.06);
}

.pcard__badge {
  position: absolute;
  top: 6px;
  left: 6px;
  font-size: 0.7rem;
  font-weight: 700;
  padding: 2px 6px;
  border-radius: 2px;
  line-height: 1.4;
}

.pcard__badge--off {
  background: #388e3c;
  color: #fff;
}

.pcard__body {
  padding: 8px 10px 12px;
}

.pcard__brand {
  font-size: 0.7rem;
  font-weight: 700;
  color: #878787;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin: 0 0 2px;
}

.pcard__name {
  font-size: 0.82rem;
  font-weight: 500;
  color: #212121;
  margin: 0 0 6px;
  line-height: 1.35;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.pcard__price-row {
  display: flex;
  align-items: baseline;
  gap: 6px;
  flex-wrap: wrap;
}

.pcard__price {
  font-size: 0.95rem;
  font-weight: 700;
  color: #212121;
}

.pcard__mrp {
  font-size: 0.75rem;
  color: #878787;
  text-decoration: line-through;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

/* Responsive Design */
@media (max-width: 768px) {
  .main_slider {
    min-height: 450px;
  }

  .main_slider_content h1 {
    font-size: 2rem;
    padding: 12px 20px;
  }

  .main_slider_content h6 {
    font-size: 1rem;
    padding: 6px 15px;
  }

  .shop-now-cta {
    padding: 13px 28px;
    font-size: 0.95rem;
  }

  .section-title {
    font-size: 2rem;
  }
  
  .section-subtitle {
    font-size: 1rem;
  }

  .new_arrivals {
    padding: 50px 0 !important;
  }

  .product-card {
    margin-bottom: 20px;
  }
}

@media (max-width: 576px) {
  .main_slider_content h1 {
    font-size: 1.5rem;
  }

  .section-title {
    font-size: 1.75rem;
  }

  .card-body {
    padding: 15px !important;
  }

  .card-footer {
    padding: 0 15px 15px !important;
  }
}
</style>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
document.addEventListener("DOMContentLoaded", () => {
  // Account menu functionality (unchanged)
  const updateAccountMenu = (elementId) => {
    const username = localStorage.getItem("username");
    const accountMenu = document.getElementById(elementId);

    if (username) {
      const firstLetter = username.charAt(0).toUpperCase();
      accountMenu.innerHTML = `
        <a href="#">
          ${firstLetter}
          <i class="fa fa-angle-down"></i>
        </a>
        <ul class="${elementId === 'accountMenu' ? 'account_selection' : 'menu_selection'}">
          <li><a href="/profile"><i class="fa fa-user"></i> Profile</a></li>
          <li><a href="#" onclick="logout()"><i class="fa fa-sign-out"></i> Logout</a></li>
        </ul>
      `;
    } else {
      accountMenu.innerHTML = `
        <a href="#">
          My Account
          <i class="fa fa-angle-down"></i>
        </a>
        <ul class="${elementId === 'accountMenu' ? 'account_selection' : 'menu_selection'}">
          <li><a href="/login"><i class="fa fa-sign-in"></i> Sign In</a></li>
          <li><a href="/register"><i class="fa fa-user-plus"></i> Register</a></li>
        </ul>
      `;
    }
  };

  updateAccountMenu('accountMenu');
  updateAccountMenu('mobileAccountMenu');
});

function logout() {
  localStorage.removeItem("username");
  window.location.href = "/";
}
</script>

<%-include('../../views/partials/user/footer')%>